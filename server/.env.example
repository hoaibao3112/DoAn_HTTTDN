# ================================
# APPLICATION CONFIGURATION
# ================================
NODE_ENV=development
PORT=5000
WS_PORT=5001

# ================================
# DATABASE CONFIGURATION
# ================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bansach
DB_USER=root
DB_PASSWORD=your_password_here

# SSL/TLS Configuration (Optional - for TiDB Cloud or secure connections)
DB_REQUIRE_SSL=false
DB_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\nYour CA certificate here\n-----END CERTIFICATE-----
# DB_SSL_CA_BASE64=base64_encoded_certificate_here

# ================================
# JWT CONFIGURATION
# ================================
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ================================
# CLIENT URLs (CORS)
# ================================
CLIENT_ADMIN_URL=http://localhost:3000
CLIENT_CUSTOMER_URL=http://localhost:5501

# ================================
# EMAIL CONFIGURATION (Optional)
# ================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ================================
# PAYMENT GATEWAYS (Optional)
# ================================
# VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/momo-return
MOMO_NOTIFY_URL=http://localhost:5000/api/payments/momo/callback

# ZaloPay
ZALOPAY_APP_ID=your_zalopay_app_id
ZALOPAY_KEY1=your_zalopay_key1
ZALOPAY_KEY2=your_zalopay_key2
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_RETURN_URL=http://localhost:3000/payment/zalopay-return

# ================================
# GOOGLE AI (Optional)
# ================================
GOOGLE_AI_API_KEY=your_google_ai_api_key

# ================================
# LOGGING CONFIGURATION
# ================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ================================
# SECURITY CONFIGURATION
# ================================
# Rate limiting (requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5501

# ================================
# UPLOAD CONFIGURATION
# ================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_PATH=./uploads

# ================================
# CRON JOBS
# ================================
ENABLE_CRON_JOBS=true

# ================================
# DEPLOYMENT (Production)
# ================================
# BASE_URL=https://your-production-domain.com
# CLIENT_ADMIN_URL=https://admin.your-domain.com
# CLIENT_CUSTOMER_URL=https://www.your-domain.com

# ================================
# MONITORING & OBSERVABILITY
# ================================
# SENTRY_DSN=your_sentry_dsn_here
# NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ================================
# NOTES
# ================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env file to git
# 3. Change JWT_SECRET in production to a strong random string
# 4. For production, set NODE_ENV=production
# 5. Use strong passwords for database
# 6. Enable SSL for production database connections
